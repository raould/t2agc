(program
;; Layer 4 — Receive primitive descriptor.
;; Returns the yield object that a task generator must yield to pause on receive.
;; Usage in a task: (let (msg) (yield (receive)))
;; The scheduler sees step.value, routes to handle_receive, and resumes
;; the generator with the incoming message as the yield value.

(export (fn receive () : object
  (return (object (type "receive") (patterns null)))))
)
