(program
;; Layer 0 — Pure type aliases (no dependencies)

(export (type Priority
  (union
    (tlit "critical")
    (tlit "high")
    (tlit "normal")
    (tlit "low")
    (tlit "idle"))))

(export (type TaskStatus
  (union
    (tlit "runnable")
    (tlit "waiting")
    (tlit "done")
    (tlit "crashed"))))

(export (type MailboxOverflowPolicy
  (union
    (tlit "drop-oldest")
    (tlit "drop-newest")
    (tlit "reject")
    (tlit "escalate")
    (tlit "block-sender"))))

(export (type CapabilityType
  (union
    (tlit "log")
    (tlit "io")
    (tlit "timer")
    (tlit "random")
    (tlit "shared-blob"))))

(export (type RestartPolicy
  (union
    (tlit "permanent")
    (tlit "transient")
    (tlit "temporary"))))

(export (type ChildType
  (union
    (tlit "worker")
    (tlit "supervisor"))))
)
