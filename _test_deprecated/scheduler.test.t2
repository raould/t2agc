(program
  ;; Unit tests for Scheduler lifecycle, priority, budget, and crash handling.

  (import (object (named (array (object (name "describe")) (object (name "it"))))) "vitest")
  (import (object (named (array (object (name "asrt")) (object (name "asrtDeep"))))) "./asrt")
  (import (object (named (array
    (object (name "init_runtime"))
    (object (name "run"))
    (object (name "spawn"))
    (object (name "get_global_scheduler"))))) "./runtime")

  (describe "Scheduler"
    (lambda ()

      (it "spawns a task and run completes it with status done"
        (lambda ()
          (init_runtime)

          ;; A generator that yields once then returns — minimal valid task
          (let (pid)
            (spawn
              (generator-fn ()
                (yield undefined)
                (yield undefined))
              (array)
              "normal"
              (new Set)))

          (run)

          (let (sched) (get_global_scheduler))
          (let (task) (sched.tasks.get pid))
          (asrt task.status "done"))

      (it "task with zero yields completes immediately"
        (lambda ()
          (init_runtime)

          (let (pid)
            (spawn
              (generator-fn () undefined)
              (array)
              "normal"
              (new Set)))

          (run)

          (let (sched) (get_global_scheduler))
          (let (task) (sched.tasks.get pid))
          (asrt task.status "done"))

      (it "budget exhaustion re-queues task — all 150 yields processed"
        (lambda ()
          ;; Default budget = 100 reductions per slice.
          ;; A generator that yields 150 plain times must be re-queued mid-way
          ;; and finish processing in two slices. We count via a shared variable.
          (init_runtime)
          (let (count) 0)

          ;; close-over `count` by mutating it inside a JS object so t2lang
          ;; let rebinding doesn't shadow the outer variable
          (let (box) (object (n 0)))

          (let (pid)
            (spawn
              (generator-fn ()
                (let (i) 0)
                (while (< i 150)
                  (yield undefined)
                  (set! (. box n) (+ (. box n) 1))
                  (set! i (+ i 1))))
              (array)
              "normal"
              (new Set)))

          (run)

          (let (sched) (get_global_scheduler))
          (let (task) (sched.tasks.get pid))
          (asrt task.status "done")
          (asrt (. box n) 150)))

      (it "pick_next_task respects priority — critical runs before idle"
        (lambda ()
          (init_runtime)
          (let (order) (array))

          ;; Spawn idle task first — it will be enqueued first in its queue
          (let (idle_pid)
            (spawn
              (generator-fn ()
                (order.push "idle"))
              (array)
              "idle"
              (new Set)))

          ;; Spawn critical task second — but higher priority queue
          (let (crit_pid)
            (spawn
              (generator-fn ()
                (order.push "critical"))
              (array)
              "critical"
              (new Set)))

          (run)

          ;; critical must have run first
          (asrt (index order 0) "critical")
          (asrt (index order 1) "idle")))

      (it "on_task_crashed — task that throws marks status crashed and emits AGC code"
        (lambda ()
          (init_runtime)

          (let (pid)
            (spawn
              (generator-fn ()
                (yield undefined)
                (throw (new Error "boom")))
              (array)
              "normal"
              (new Set)))

          (run)

          (let (sched) (get_global_scheduler))
          (let (task)  (sched.tasks.get pid))
          (let (codes) (. sched agc_codes_emitted))

          (asrt task.status "crashed")
          ;; AGC-S999 should be in emitted codes
          (let (found) false)
          (let (i) 0)
          (while (< i codes.length)
            (if (=== (. (index codes i) code) "AGC-S999")
              (then (set! found true)))
            (set! i (+ i 1)))
          (asrt found true)))

      (it "multiple tasks all reach done after run"
        (lambda ()
          (init_runtime)

          (let (pid1) (spawn (generator-fn () undefined) (array) "normal" (new Set)))
          (let (pid2) (spawn (generator-fn () undefined) (array) "high"   (new Set)))
          (let (pid3) (spawn (generator-fn () undefined) (array) "low"    (new Set)))

          (run)

          (let (sched) (get_global_scheduler))
          (let (t1) (sched.tasks.get pid1))
          (let (t2) (sched.tasks.get pid2))
          (let (t3) (sched.tasks.get pid3))
          (asrt t1.status "done")
          (asrt t2.status "done")
          (asrt t3.status "done")))

      (it "total_reductions increments once per gen.next call"
        (lambda ()
          (init_runtime)

          ;; 3 yields + final return = 4 gen.next calls = 4 reductions
          (let (pid)
            (spawn
              (generator-fn ()
                (yield undefined)
                (yield undefined)
                (yield undefined))
              (array)
              "normal"
              (new Set)))

          (run)

          (let (sched) (get_global_scheduler))
          (let (task) (sched.tasks.get pid))
          ;; 3 yields + 1 return step = 4
          (asrt task.total_reductions 4)))))))
)
