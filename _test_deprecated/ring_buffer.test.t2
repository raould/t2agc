(program
  (import (object (named (array (object (name "describe")) (object (name "it"))))) "vitest")
  (import (object (named (array (object (name "asrt")) (object (name "asrtDeep"))))) "./asrt")
  (import (object (named (array (object (name "RingBuffer"))))) "./ring_buffer")

  (let* ((rb (new RingBuffer 3)))
    (describe "RingBuffer"
      (lambda ()
        (it "push and to_array"
          (lambda ()
            (asrt (rb.push 1) undefined)
            (asrt (rb.push 2) undefined)
            (asrt (rb.push 3) undefined)
            (asrtDeep (rb.to_array) [1, 2, 3])
            (rb.push 4)
            (asrtDeep (rb.to_array) [2, 3, 4]))))))
)