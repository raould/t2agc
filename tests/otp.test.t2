(program
  ;; Unit tests for OTP primitives: restart_child, registry_fn, supervisor_fn.
  ;;
  ;; The registry and supervisor are generator-based actors — they must be
  ;; spawned and exercised via message passing, not called directly.

  (import (object (named (array (object (name "describe")) (object (name "it"))))) "vitest")
  (import (object (named (array (object (name "asrt")) (object (name "asrtDeep"))))) "./asrt")
  (import (object (named (array
    (object (name "init_runtime"))
    (object (name "run"))
    (object (name "spawn"))
    (object (name "send"))
    (object (name "get_global_scheduler"))))) "./runtime")
  (import (object (named (array
    (object (name "restart_child"))
    (object (name "registry_fn"))
    (object (name "supervisor_fn"))))) "./otp")

  ;; ── Helpers ──────────────────────────────────────────────────────────────────

  (fn noop_gen () : any
    ;; Minimal generator task that finishes immediately.
    (return (generator-fn () (yield undefined))))

  (fn make_spec ((id : any) (start : Function)) : any
    ;; Construct a minimal ChildSpec.
    (return
      (object
        (id               id)
        (start            start)
        (capabilities     (array))
        (priority         "normal")
        (restart_policy   "permanent")
        (shutdown_timeout 1000)
        (type             "worker"))))

  ;; ── restart_child ─────────────────────────────────────────────────────────

  (describe "restart_child"
    (lambda ()

      (it "returns a numeric pid"
        (lambda ()
          (init_runtime)
          (let (pid) (restart_child (make_spec (Symbol.for "w") (noop_gen))))
          (asrt (typeof pid) "number")))

      (it "spawned task appears in scheduler.tasks"
        (lambda ()
          (init_runtime)
          (let (pid) (restart_child (make_spec (Symbol.for "w") (noop_gen))))
          (let (sched) (get_global_scheduler))
          (asrt (!= (sched.tasks.get pid) undefined) true)))

      (it "spawned task reaches done after run"
        (lambda ()
          (init_runtime)
          (let (pid) (restart_child (make_spec (Symbol.for "w") (noop_gen))))
          (run)
          (let (sched) (get_global_scheduler))
          (let (task) (sched.tasks.get pid))
          (asrt task.status "done"))

      (it "each restart_child call spawns a distinct task with a unique pid"
        (lambda ()
          (init_runtime)
          (let (gen) (noop_gen))
          (let (pid1) (restart_child (make_spec (Symbol.for "a") gen)))
          (let (pid2) (restart_child (make_spec (Symbol.for "b") gen)))
          (asrt (!= pid1 pid2) true)))))

  ;; ── Registry ─────────────────────────────────────────────────────────────────

  (describe "Registry"
    (lambda ()

      (it "register then whereis returns the pid"
        (lambda ()
          (init_runtime)
          (let (results) (array))

          ;; Spawn registry actor
          (let (reg_pid)
            (spawn registry_fn (array null) "normal" (new Set)))

          ;; Collector: receives the whereis reply and stores it
          (let (collector_pid)
            (spawn
              (generator-fn ()
                (let (msg) (yield (object (type "receive") (patterns null))))
                (results.push msg))
              (array)
              "normal"
              (new Set)))

          ;; register "alice" → pid 42
          (send reg_pid (array "register" "alice" 42))
          ;; ask "whereis alice", reply to collector
          (send reg_pid (array "whereis" "alice" collector_pid))

          (run)

          (asrtDeep results (array 42))))

      (it "unregister then whereis returns undefined"
        (lambda ()
          (init_runtime)
          (let (results) (array))

          (let (reg_pid)
            (spawn registry_fn (array null) "normal" (new Set)))

          (let (collector_pid)
            (spawn
              (generator-fn ()
                (let (msg) (yield (object (type "receive") (patterns null))))
                (results.push msg))
              (array)
              "normal"
              (new Set)))

          (send reg_pid (array "register"   "bob" 99))
          (send reg_pid (array "unregister" "bob"))
          (send reg_pid (array "whereis"    "bob" collector_pid))

          (run)

          ;; Map.get returns undefined for a missing key
          (asrt (index results 0) undefined)))))

  ;; ── Supervisor ───────────────────────────────────────────────────────────────

  (describe "Supervisor"
    (lambda ()

      (it "starts all child specs and they reach done after run"
        (lambda ()
          (init_runtime)

          (let (spec1) (make_spec (Symbol.for "child1") (noop_gen)))
          (let (spec2) (make_spec (Symbol.for "child2") (noop_gen)))
          (let (child_specs) (array spec1 spec2))

          ;; Supervisor itself runs as a task
          (let (sup_pid)
            (spawn supervisor_fn
              (array child_specs "one-for-one" 3 5000)
              "normal"
              (new Set)))

          (run)

          ;; Two workers were spawned by the supervisor's init loop.
          ;; The supervisor is a long-running task so it will be waiting;
          ;; the two workers should be done.
          (let (sched) (get_global_scheduler))
          (let (done_count) 0)
          (sched.tasks.forEach
            (lambda ((task : any) (pid : number))
              (if (=== task.status "done")
                (then (set! done_count (+ done_count 1))))))

          ;; At least the two noop workers finished
          (asrt (>= done_count 2) true)))

      (it "permanent child is restarted when sent an exit message"
        (lambda ()
          (init_runtime)
          (let (child_id) (Symbol.for "worker"))
          (let (spec) (make_spec child_id (noop_gen)))
          (let (child_specs) (array spec))

          (let (sup_pid)
            (spawn supervisor_fn
              (array child_specs "one-for-one" 3 5000)
              "normal"
              (new Set)))

          ;; Let the supervisor and first worker start
          (run)

          ;; Find the first worker pid that was spawned
          (let (sched) (get_global_scheduler))
          (let (task_count_before) (. sched.tasks size))

          ;; Re-init so we can do a second run with the supervisor still alive
          ;; NOTE: supervisor is in "waiting" state after first run — re-run
          ;; will process the exit message we send it.
          (send sup_pid (array "exit" child_id "crash"))
          (run)

          ;; A new task should have been spawned for the permanent child
          (let (task_count_after) (. sched.tasks size))
          (asrt (> task_count_after task_count_before) true))))))
)
