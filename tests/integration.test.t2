(program
  ;; High-level integration test: exercises all five core areas
  ;; in one file without chasing deep code-coverage metrics.
  ;;
  ;; Areas covered:
  ;;   1. match_pattern — pure pattern matching utilities
  ;;   2. capability    — Capability class and factory functions
  ;;   3. scheduler     — init_runtime / spawn / run lifecycle
  ;;   4. send/receive  — inter-task message passing (counter actor)
  ;;   5. otp           — restart_child + task spawned via ChildSpec

  (import (object (named (array (object (name "describe")) (object (name "it"))))) "vitest")
  (import (object (named (array (object (name "asrt")) (object (name "asrtDeep"))))) "./asrt")

  (import (object (named (array (object (name "match_pattern"))
                               (object (name "compute_match_result"))))) "./match_pattern")

  (import (object (named (array (object (name "make_log_capability"))
                               (object (name "make_random_capability"))))) "./capability")

  (import (object (named (array (object (name "init_runtime"))
                               (object (name "run"))
                               (object (name "spawn"))
                               (object (name "send"))
                               (object (name "get_global_scheduler"))))) "./runtime")

  (import (object (named (array (object (name "restart_child"))))) "./otp")

  (describe "t2-agc integration"
    (lambda ()

      ;; ── 1. match_pattern ────────────────────────────────────────────────────

      (describe "match_pattern"
        (lambda ()

          (it "wildcard _ matches any value"
            (lambda ()
              (let (b) (match_pattern "_" 42 (object)))
              (asrt (!= b null) true)))

          (it "string literal matches exactly, or returns null"
            (lambda ()
              (asrt (!= (match_pattern "ping" "ping" (object)) null) true)
              (asrt (match_pattern "ping" "pong" (object)) null)))

          (it "array pattern — structural match and length mismatch"
            (lambda ()
              (let (b) (match_pattern (array "inc" "_") (array "inc" 5) (object)))
              (asrt (!= b null) true)
              (asrt (match_pattern (array "inc" "_") (array "inc" 5 99) (object)) null)))

          (it "compute_match_result finds first matching pattern by index"
            (lambda ()
              (let (patterns)
                (array
                  (object (pattern (array "add" "_")))
                  (object (pattern (array "sub" "_")))))
              (let (r1) (compute_match_result (array "sub" 3) patterns))
              (asrt (!= r1 null) true)
              (asrt r1.matched_pattern_index 1)
              (asrt (compute_match_result (array "mul" 3) patterns) null)))))

      ;; ── 2. capability ───────────────────────────────────────────────────────

      (describe "capability"
        (lambda ()

          (it "make_log_capability has correct type and operations"
            (lambda ()
              (let (cap) (make_log_capability))
              (asrt cap.cap_type "log")
              (asrt (cap.can_perform "info")  true)
              (asrt (cap.can_perform "write") false)))

          (it "each capability instance gets a unique id"
            (lambda ()
              (let (a) (make_random_capability))
              (let (b) (make_random_capability))
              (asrt (!= a.id b.id) true)))))

      ;; ── 3 + 4. scheduler + send/receive ─────────────────────────────────────
      ;;
      ;; Counter actor: holds a numeric state.
      ;;   - ["inc", n]         → adds n to state, loops
      ;;   - ["get", reply_pid] → sends ["result", state] to reply_pid, exits
      ;;
      ;; Driver: sends two increments then a query; collector receives the reply.
      ;; Since the scheduler is synchronous, run() returns only after both tasks
      ;; are done.  A shared JS array captures the reply for assertion.

      (describe "scheduler and send/receive"
        (lambda ()

          (it "counter actor accumulates over two increments"
            (lambda ()
              (init_runtime)
              (let (results) (array))

              (let (counter_gen)
                (generator-fn ()
                  (let (state) 0)
                  (let (running) true)
                  (while running
                    (let (msg)
                      (yield (object (type "receive") (patterns null))))
                    (if (=== (index msg 0) "inc")
                      (then
                        (set! state (+ state (index msg 1))))
                      (else
                        (send (index msg 1) (array "result" state))
                        (set! running false))))))

              (let (collector_gen)
                (generator-fn ()
                  (let (msg)
                    (yield (object (type "receive") (patterns null))))
                  (results.push (index msg 1))))

              (let (counter_pid)
                (spawn counter_gen (array) "normal" (new Set)))
              (let (collector_pid)
                (spawn collector_gen (array) "normal" (new Set)))

              (send counter_pid (array "inc" 5))
              (send counter_pid (array "inc" 3))
              (send counter_pid (array "get" collector_pid))

              (run)

              (asrtDeep results (array 8))))

          (it "send to non-existent pid emits AGC-M050"
            (lambda ()
              (init_runtime)
              (send 9999 "hello")
              (let (scheduler) (get_global_scheduler))
              (let (codes) (. scheduler agc_codes_emitted))
              (asrt (> codes.length 0) true)
              (let (first) (index codes 0))
              (asrt first.code "AGC-M050")))))

      ;; ── 5. otp — restart_child ───────────────────────────────────────────────
      ;;
      ;; restart_child(spec) spawns spec.start with the given priority and
      ;; capabilities, registers the task in the scheduler, and returns the pid.
      ;; We verify that a real task object appears in the scheduler map.

      (describe "otp"
        (lambda ()

          (it "restart_child spawns a task and returns its pid"
            (lambda ()
              (init_runtime)

              (let (noop_fn)
                (generator-fn ()
                  (yield undefined)))

              (let (spec)
                (object
                  (id           (Symbol.for "worker"))
                  (start        noop_fn)
                  (capabilities (array))
                  (priority     "normal")
                  (restart_policy "permanent")
                  (shutdown_timeout 1000)
                  (type         "worker")))

              (let (pid) (restart_child spec))

              (asrt (typeof pid) "number")
              (let (scheduler) (get_global_scheduler))
              (asrt (!= (scheduler.tasks.get pid) undefined) true)

              ;; Run so the noop task finishes cleanly
              (run)
              (let (task) (scheduler.tasks.get pid))
              (asrt task.status "done")))))

    ))
)
