(program
  ;; Unit tests for inter-task messaging: send, basic receive,
  ;; selective receive, mailbox overflow, and the AGC-M050 dead-letter path.

  (import (object (named (array (object (name "describe")) (object (name "it"))))) "vitest")
  (import (object (named (array (object (name "asrt")) (object (name "asrtDeep"))))) "./asrt")
  (import (object (named (array
    (object (name "init_runtime"))
    (object (name "run"))
    (object (name "spawn"))
    (object (name "send"))
    (object (name "get_global_scheduler"))))) "./runtime")

  (describe "send / receive"
    (lambda ()

      (it "basic send then receive delivers the message"
        (lambda ()
          ;; Task A sends a value to task B.
          ;; Task B receives it and writes it to a shared box.
          (init_runtime)
          (let (box) (object (val null)))

          (let (b_pid)
            (spawn
              (generator-fn ()
                (let (msg) (yield (object (type "receive") (patterns null))))
                (set! (. box val) msg))
              (array)
              "normal"
              (new Set)))

          ;; Pre-seed mailbox before run — message is already waiting when B starts
          (send b_pid "hello")

          (run)

          (asrt (. box val) "hello")))

      (it "two tasks exchange a message via a reply pid"
        (lambda ()
          (init_runtime)
          (let (results) (array))

          (let (echo_gen)
            (generator-fn ()
              (let (msg) (yield (object (type "receive") (patterns null))))
              ;; msg is [value, reply_pid]
              (send (index msg 1) (+ (index msg 0) 1))))

          (let (client_gen)
            (generator-fn ()
              ;; receive the echoed result
              (let (reply) (yield (object (type "receive") (patterns null))))
              (results.push reply)))

          (let (echo_pid)   (spawn echo_gen   (array) "normal" (new Set)))
          (let (client_pid) (spawn client_gen (array) "normal" (new Set)))

          ;; Client sends [10, client_pid] to echo; echo will send 11 back
          (send echo_pid (array 10 client_pid))

          (run)

          (asrtDeep results (array 11))))

      (it "selective receive matches correct pattern by index"
        (lambda ()
          ;; Task receives with two patterns: ["add", n] or ["sub", n].
          ;; We send an ["sub", 5] message — expect matched_pattern_index = 1.
          (init_runtime)
          (let (box) (object (idx -1) (val null)))

          (let (pid)
            (spawn
              (generator-fn ()
                (let (result)
                  (yield (object
                    (type "receive")
                    (patterns (array
                      (object (pattern (array "add" "_")))
                      (object (pattern (array "sub" "_"))))))))
                (set! (. box idx) result.matched_pattern_index)
                (set! (. box val) (index result.message 1)))
              (array)
              "normal"
              (new Set)))

          (send pid (array "sub" 5))
          (run)

          (asrt (. box idx) 1)
          (asrt (. box val) 5)))

      (it "selective receive — first matching pattern wins"
        (lambda ()
          (init_runtime)
          (let (box) (object (idx -1)))

          (let (pid)
            (spawn
              (generator-fn ()
                (let (result)
                  (yield (object
                    (type "receive")
                    (patterns (array
                      (object (pattern "_"))
                      (object (pattern "x")))))))
                (set! (. box idx) result.matched_pattern_index))
              (array)
              "normal"
              (new Set)))

          ;; "x" matches both wildcard (index 0) and literal (index 1)
          ;; wildcard at index 0 must win
          (send pid "x")
          (run)

          (asrt (. box idx) 0)))

      (it "send to non-existent pid emits AGC-M050"
        (lambda ()
          (init_runtime)
          (send 9999 "hello")
          (let (sched) (get_global_scheduler))
          (let (codes) (. sched agc_codes_emitted))
          (asrt (> codes.length 0) true)
          (let (first) (index codes 0))
          (asrt first.code "AGC-M050")))

      (it "mailbox overflow drop-oldest discards head and emits AGC-M010"
        (lambda ()
          (init_runtime)

          ;; Spawn a task that never reads its mailbox — just returns immediately
          (let (pid)
            (spawn
              (generator-fn () undefined)
              (array)
              "normal"
              (new Set)))

          ;; Configure a very small mailbox (max 2) with drop-oldest policy
          (let (sched) (get_global_scheduler))
          (let (task)  (sched.tasks.get pid))
          (task.configure_mailbox 2 "drop-oldest")

          ;; Send 3 messages — third send must overflow and drop the first
          (send pid "first")
          (send pid "second")
          (send pid "third")

          ;; Check AGC-M010 was emitted
          (let (codes) (. sched agc_codes_emitted))
          (let (found) false)
          (let (i) 0)
          (while (< i codes.length)
            (if (=== (. (index codes i) code) "AGC-M010")
              (then (set! found true)))
            (set! i (+ i 1)))
          (asrt found true)

          ;; Mailbox should now contain only the last 2 messages
          (asrtDeep task.mailbox (array "second" "third"))))

      (it "message pre-seeded before run is delivered on first receive"
        (lambda ()
          ;; Verifies the pre-seeding path: message arrives before task starts,
          ;; task picks it up immediately without entering waiting state.
          (init_runtime)
          (let (box) (object (val null)))

          (let (pid)
            (spawn
              (generator-fn ()
                (let (msg) (yield (object (type "receive") (patterns null))))
                (set! (. box val) msg))
              (array)
              "normal"
              (new Set)))

          ;; Seed before run
          (send pid "pre-seeded")
          (run)

          (let (sched) (get_global_scheduler))
          (let (task) (sched.tasks.get pid))
          (asrt task.status "done")
          (asrt (. box val) "pre-seeded")))))
)
