{
  "name": "t2agc",
  "version": "0.0.1",
  "description": "safer concurrency",
  "license": "CC0-1.0",
  "author": "",
  "type": "module",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "build": "npx t2tc --outDir dist src/*.t2",
    "build-tests": "rimraf dist-tests && npx t2tc --outDir dist-tests src/*.t2 && npx t2tc --outDir dist-tests tests/*.t2",
    "test": "npm run build-tests && npx vitest --typecheck run",
    "testnow": "npx vitest --typecheck run"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "rimraf": "^6.1.3",
    "t2lang": "file:../t2lang",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "stage9": "file:../t2lang/stage9"
  }
}
